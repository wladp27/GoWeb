@model List<RoleView>
@if (TempData["ErrorMessage"] != null)
{
	<div class="alert alert-success">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="mt-3">
@{
	foreach(var role in Model)
	{
			<div class="container-sm border p-3 mb-4 rounded shadow-lg bg-white">
				<div class="row">
					<div class="col-md-6">
						<h3 class="mb-3 text-primary">@role.Name</h3>
						<p class="text-muted small">ID роли: @role.Id</p>
					</div>
					<div class="col-md-6">
						<div class="row">
							<div class="col-md-6">
								<a asp-area="Admin" asp-controller="Role" asp-action="EditRole" asp-route-id="@role.Id" class="btn btn-primary">Редактировать</a>
							</div>
							<div class="col-md-6">
								<a asp-area="Admin" asp-controller="Role" asp-action="Delete" asp-route-id="@role.Id" class="btn btn-primary">Удалить</a>
							</div>
						</div>
						</div>
				</div>
			</div>
			
	}
}
</div>

<div class="row">
	<div class="col-md-6">
		<a asp-area="Admin" asp-controller="Role" asp-action="Create" class="btn btn-primary">Создать роль</a>
	</div>
	<div class="col-md-6">
		<a asp-area="Admin" asp-controller="Role" asp-action="EditRolesUser" class="btn btn-primary">Добавить роль пользователю</a>
	</div>
</div>
