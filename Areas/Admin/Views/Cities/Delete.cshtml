@model GoWeb.Models.CityViewModel
@{
    ViewData["Title"] = "Удалить Город";
}

<h3 class="text-danger">Вы уверены, что хотите удалить этот город?</h3>
<hr>

<div>
    <h4>Город</h4>

    <dl class="row">

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.NameCity)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.NameCity)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.LocationLatitude)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.LocationLatitude)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.LocationLongitude)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.LocationLongitude)
        </dd>

    </dl>

    <form asp-action="Delete" method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <input type="submit" value="Удалить" class="btn btn-danger" />

        <a asp-action="Index" class="btn btn-secondary">Отмена</a>

    </form>
</div>