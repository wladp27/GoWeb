@model EventTypeViewMode

<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImagePath" class="control-label"></label>
                <input asp-for="ImagePath" />
                <span asp-validation-for="ImagePath" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mt-3">
                <input type="submit" value="Редактировать" class="btn btn-primary" />
            </div>
        </form>
        <a asp-area="Admin" asp-controller="EventType" asp-action="Index" class="btn btn-primary">Список типов событий</a>
    </div>
</div>

