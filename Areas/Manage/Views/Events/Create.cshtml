            </div>


            <div class="grid grid-cols-2 gap-6 bg-blue-50 p-4 rounded-xl border border-blue-100">
                <div class="form-group">
                    <label asp-for="MinParticipants" class="block text-sm font-bold text-blue-800">Мин. участников</label>
                    <input asp-for="MinParticipants" class="w-full border border-blue-200 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                </div>
                <div class="form-group">
                    <label asp-for="MaxParticipants" class="block text-sm font-bold text-blue-800">Макс. участников</label>
                    <input asp-for="MaxParticipants" class="w-full border border-blue-200 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                </div>
            </div>

      
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <div class="flex items-center space-x-3 mb-2">
                    <input type="checkbox" id="toggleCheck" class="w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                    <label class="text-sm font-bold text-gray-700 cursor-pointer" for="toggleCheck">
                        Автосоздание события
                    </label>
                </div>
                <div id="numberInputBlock" style="display: none;" class="mt-3 animate-pulse-once">
                    <label asp-for="CountDaysRecreate" class="block text-xs font-semibold text-gray-500 mb-1 italic">Через сколько дней повторить?</label>
                    <input asp-for="CountDaysRecreate" type="number" class="w-full border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                </div>
            </div>

           
            <div class="mt-6 border-t pt-6">
                <label class="font-bold text-gray-800 block mb-3 text-lg">Организатор</label>
                <div class="flex gap-2 mb-4">
                    <input type="text" id="NameInput" placeholder="Введите никнейм..."
                           class="flex-1 border p-3 rounded-xl border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none shadow-sm">
                </div>
                <div id="loader" class="hidden py-4 flex flex-col items-center">
                    <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-blue-600"></div>
                </div>
                <div id="resultsContainer" class="max-h-48 overflow-y-auto space-y-2 rounded-lg"></div>
            </div>

            <input type="hidden" asp-for="ImagePath" />
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OrganizerId" />
            <input type="hidden" asp-for="EventTypes" />

            <input type="hidden" asp-for="StatusEvents" />

            <input type="hidden" asp-for=EventTypeId />
            <input type="hidden" asp-for="LocationId" />

            <div class="pt-6">
                <button type="submit" disabled="true" id="buttonEventSave" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 rounded-2xl shadow-xl transform transition active:scale-95 text-lg uppercase tracking-wider 
                                                                  disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed">
                    СОЗДАТЬ СОБЫТИЕ
                </button>
            </div>
        </form>
    </div>
</div>






<script src="https://cdn.tailwindcss.com"></script>

<script>

    let searchTimeout; 
    async function getUsers() {
        const nameInput = document.getElementById('NameInput');
        const resultsContainer = document.getElementById('resultsContainer');
        const idUser = document.getElementById('OrganizerId');
        const name = nameInput.value.trim();
        const loader = document.getElementById('loader');

        if (!name) {
            resultsContainer.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Введите никнейм для поиска</div>';
            return;
        }

        loader.classList.remove('hidden');
        try {
            const response = await fetch(`/Manage/Events/GetUsers?userName=${encodeURIComponent(name)}`);
            if (!response.ok) throw new Error(`Ошибка сервера`);

            const listUser = await response.json();

            if (!listUser || listUser.length === 0) {
                resultsContainer.innerHTML = '<div class="text-gray-500 text-sm italic p-3 text-center">Никого не нашли...</div>';
                return;
            }
            resultsContainer.innerHTML = '';
            listUser.forEach(user => {
                const userElement = document.createElement('div');
                userElement.className = "p-3 border border-gray-200 rounded-xl hover:bg-blue-50 cursor-pointer flex justify-between items-center bg-white transition hover:border-blue-300 mb-2";
                userElement.innerHTML = `<span class="font-bold text-gray-700">${user.userName}</span> <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full uppercase">Выбрать</span>`;

                userElement.onclick = () => {
                    nameInput.value = user.userName;
                    resultsContainer.innerHTML = `<div class="p-3 bg-green-50 text-green-700 rounded-xl border border-green-200 flex items-center font-bold">✓ Выбран: ${user.userName}</div>`;
                    idUser.value = user.id;
                    nameInput.dataset.selected = "true";
                };
                resultsContainer.appendChild(userElement);
            });
        } catch (error) {
            resultsContainer.innerHTML = '<div class="text-red-500 p-3 bg-red-50 rounded-lg">Ошибка загрузки данных</div>';
        } finally {
            loader.classList.add('hidden');
        }
    }

    document.getElementById('NameInput').addEventListener('input', (e) => {
        e.target.dataset.selected = "false";
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            if (e.target.dataset.selected !== "true") {
                getUsers();
            }
        }, 1000);
    });




    let searchTimeout2;
    const listEventType = @Html.Raw(Json.Serialize(Model.EventTypes));
    
    function filterTypeEvent() {
        const EventTypeInput = document.getElementById('TypeEventInput');
        const resultsContainer = document.getElementById('resultsContainerTypeEvent');
        const idEventType = document.getElementById('EventTypeId');
        const evT = EventTypeInput.value.toLowerCase().trim();
        const loader = document.getElementById('typeEvenloader');

        if (!evT) {
            resultsContainer.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Введите тип события для поиска</div>';
            return;
        }

        loader.classList.remove('hidden');
        const filtered = listEventType.filter(item =>
            item.text.toLowerCase().includes(evT));

        try {
            if (!filtered || filtered.length === 0) {
                resultsContainer.innerHTML = '<div class="text-gray-500 text-sm italic p-3 text-center">Ничего не нашли...</div>';
                return;
            }
            resultsContainer.innerHTML = '';
            filtered.forEach(eventT => {
                const EventTypeElement = document.createElement('div');
                EventTypeElement.className = "p-3 border border-gray-200 rounded-xl hover:bg-blue-50 cursor-pointer flex justify-between items-center bg-white transition hover:border-blue-300 mb-2";
                EventTypeElement.innerHTML = `<span class="font-bold text-gray-700">${eventT.text}</span> <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full uppercase">Выбрать</span>`;

                EventTypeElement.onclick = () => {
                    EventTypeInput.value = eventT.text;
                    resultsContainer.innerHTML = `<div class="p-3 bg-green-50 text-green-700 rounded-xl border border-green-200 flex items-center font-bold">✓ Выбран: ${eventT.text}</div>`;
                    idEventType.value = eventT.value;
                    EventTypeInput.dataset.selected = "true";
                };
                resultsContainer.appendChild(EventTypeElement);
            });
        } catch (error) {
            resultsContainer.innerHTML = '<div class="text-red-500 p-3 bg-red-50 rounded-lg">Ошибка загрузки данных</div>';
        } finally {
            loader.classList.add('hidden');
        }
    }

    document.getElementById('TypeEventInput').addEventListener('input', (e) => {
        e.target.dataset.selected = "false";
        clearTimeout(searchTimeout2);
        searchTimeout2 = setTimeout(() => {
            if (e.target.dataset.selected !== "true") {
                filterTypeEvent();
            }
        }, 1000);
    });


    let searchTimeout3;
    async function getLocations() {
        const nameInput = document.getElementById('AddressInput');
        const resultsContainer = document.getElementById('resultsAddressContainer');
        const idLocation = document.getElementById('LocationId');
        const name = nameInput.value.trim();
        const loader = document.getElementById('loaderAddress');
        const btn = document.getElementById("buttonEventSave");
        const selectedCity =  document.getElementById("selectedCity");

        if(!selectedCity.value)
        {
            resultsContainer.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Выберите город</div>';
            btn.disabled = true;
            return;
        }

        if (!name) {
            resultsContainer.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Введите адресс локации</div>';
            btn.disabled = true;
            return;
        }

        

        loader.classList.remove('hidden');
        idLocation.value = "";
        try {
            const response = await fetch(`/Manage/Events/GetLocations?address=${encodeURIComponent(name)}&idCity=${encodeURIComponent(selectedCity.value)}`);
            if (!response.ok) throw new Error(`Ошибка сервера`);
            const listLocation = await response.json();
            if (!listLocation || listLocation.length === 0) {
                resultsContainer.innerHTML = '<div class="text-gray-500 text-sm italic p-3 text-center">Никого не нашли...</div>';
                btn.disabled = true;
                return;
            }
            resultsContainer.innerHTML = '';
            listLocation.forEach(location => {
                const locationElement = document.createElement('div');
                locationElement.className = "p-3 border border-gray-200 rounded-xl hover:bg-blue-50 cursor-pointer flex justify-between items-center bg-white transition hover:border-blue-300 mb-2";
                locationElement.innerHTML = `<span class="font-bold text-gray-700">${location.address}</span> <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full uppercase">Выбрать</span>`;

                locationElement.onclick = () => {
                    nameInput.value = location.address;
                    resultsContainer.innerHTML = `<div class="p-3 bg-green-50 text-green-700 rounded-xl border border-green-200 flex items-center font-bold">✓ Выбран: ${location.address}</div>`;
                    idLocation.value = location.id;
                    nameInput.dataset.selected = "true";
                    btn.disabled = false;
                };
                resultsContainer.appendChild(locationElement);
            });
        } catch (error) {
            resultsContainer.innerHTML = '<div class="text-red-500 p-3 bg-red-50 rounded-lg">Ошибка загрузки данных</div>';
        } finally {
            loader.classList.add('hidden');
        }
    }

    document.getElementById('AddressInput').addEventListener('input', (e) => {
        e.target.dataset.selected = "false";
        clearTimeout(searchTimeout3);
        searchTimeout3 = setTimeout(() => {
            if (e.target.dataset.selected !== "true") {
                getLocations();
            }
        }, 1000);
    });

    


    document.getElementById('toggleCheck').addEventListener('change', function() {
        const block = document.getElementById('numberInputBlock');
        block.style.display = this.checked ? 'block' : 'none';
        if (!this.checked) block.querySelector('input').value = '';
    });
</script>


<script>
        document.addEventListener("DOMContentLoaded", function () {
        const checkbox = document.getElementById('toggleLocation');
        const locationContainer = document.getElementById('locationFields');
        const idLocation = document.getElementById('LocationId');
        const containerInputAddress =   document.getElementById("ContainerInputAddress");
        const resultsContainer = document.getElementById('resultsAddressContainer');
        const nameInput = document.getElementById('AddressInput');
        const btn= document.getElementById("buttonEventSave");
        function toggleFields() {
            if (checkbox.checked) {
                if(map==null)
                {
                    initMap(53.20007,50.15);
                }
                
                locationContainer.classList.remove('hidden');
                locationContainer.disabled = false;
                containerInputAddress.classList.add('hidden');
                idLocation.value = "";
                resultsContainer.innerHTML = '';
                nameInput.value = "";
                btn.disabled = true;
            } else {
                 locationContainer.classList.add('hidden');
                 locationContainer.disabled = true;
                 containerInputAddress.classList.remove('hidden');
                btn.disabled = true;
            }
        }

        checkbox.addEventListener('change', toggleFields);

        // Вызываем один раз при загрузке, чтобы проверить состояние (например, если страница перезагрузилась с ошибкой валидации)
        toggleFields();
    });
</script>




