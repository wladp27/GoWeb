@model EventCreateUpdateViewModel


<div class="container mx-auto px-4 py-12 min-h-screen">

    <div class="max-w-3xl mx-auto">
        <h3 class="text-3xl font-extrabold text-gray-900 mb-8 text-center">Создать событие</h3>

        <form asp-action="Create" method="post" enctype="multipart/form-data"  class="space-y-6 bg-white p-8 shadow-2xl rounded-2xl border border-gray-100">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                    <label asp-for="EventName" class="block text-sm font-bold text-gray-700 mb-1"></label>
                    <input asp-for="EventName" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none transition" />
                    <span asp-validation-for="EventName" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="block text-sm font-bold text-gray-700 mb-1"></label>
                    <input asp-for="Price" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none transition" />
                    <span asp-validation-for="Price" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

         
            <div class="form-group">
                <label asp-for="EventDescription" class="block text-sm font-bold text-gray-700 mb-1"></label>
                <textarea asp-for="EventDescription" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none transition" rows="3"></textarea>
                <span asp-validation-for="EventDescription" class="text-red-500 text-xs mt-1"></span>
            </div>

        
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                <div class="form-group">
                    <label class="block text-sm font-bold text-gray-700 mb-1">Тип события</label>
                    <div class="flex gap-2 mb-4">
                        <input type="text" id="TypeEventInput" placeholder="Введите тип события..."
                               class="flex-1 border p-3 rounded-xl border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none shadow-sm">
                    </div>
                    <div id="typeEvenloader" class="hidden py-4 flex flex-col items-center">
                        <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-blue-600"></div>
                    </div>
                    <div id="resultsContainerTypeEvent" class="max-h-48 overflow-y-auto space-y-2 rounded-lg"></div>
                </div>

                <div class="form-group">
                    <label asp-for="StatusEventId" class="block text-sm font-bold text-gray-700 mb-1"></label>
                    <select asp-for="StatusEventId" asp-items="Model.StatusEvents" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none"> 
                        <option value="">-- Выбрать --</option> 
                     </select> 
                    <span asp-validation-for="StatusEventId" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>


            <div id="ContainerInputAddress" class="mt-6 border-t pt-6">
                <label id="LabelInputAddres" class="font-bold text-gray-800 block mb-3 text-lg">Выбор локации</label>

                <div class="max-w-4xl mx-auto">
                    <div class="flex gap-3">
                        <select id="selectedCity" asp-items="Model.Location.Cities" class="w-1/3 border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none">
                            <option value="">Город проведения</option>
                        </select>
                        <input type="text"
                               id="AddressInput"
                               placeholder="Введите адрес локации..."
                               class="hidden flex-[2] px-4 py-3 bg-white border rounded-xl shadow-sm outline-none transition-all
                              @(ViewData.ModelState.ContainsKey("AddressInput") && ViewData.ModelState["AddressInput"].Errors.Count > 0
                                ? "border-red-500 ring-4 ring-red-500/10"
                                : "border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10")">
                                </div>
                    @if (ViewData.ModelState.ContainsKey("AddressInput") && ViewData.ModelState["AddressInput"].Errors.Count > 0)
                    {
                        <span class="text-red-500 text-sm mt-1 ml-1">
                            @ViewData.ModelState["AddressInput"].Errors[0].ErrorMessage
                        </span>
                    }
                </div>


                <div id="loaderAddress" class="hidden py-4 flex flex-col items-center">
                    <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-blue-600"></div>
                </div>
                <div id="resultsAddressContainer" class="max-h-48 overflow-y-auto space-y-2 rounded-lg"></div>

            </div>



            <!-- 1. Добавляем чекбокс -->
            <div class="mb-6 flex items-center">
                <input type="checkbox" id="toggleLocation" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                <label for="toggleLocation" class="ml-2 text-sm font-medium text-gray-900 cursor-pointer">
                    Создать новую локацию
                </label>
            </div>

  <fieldset id="locationFields" disabled class="space-y-6 hidden">
    <!-- Основная сетка формы -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- ЛЕВАЯ КОЛОНКА (Выбор города + Карта) -->
        <div class="space-y-4">
            <div class="form-group">
                <label asp-for="Location.CityId" class="block text-sm font-bold text-gray-700 mb-1">Город</label>
                <select id="selectLocationCityId" asp-for="Location.CityId" asp-items="Model.Location.Cities" 
                        class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                    <option value="">-- Выбрать --</option>
                </select>
                <span asp-validation-for="Location.CityId" class="text-red-500 text-xs mt-1"></span>
                <!-- Валидация под городом -->
                <div id="validationNewAddress" class="w-full max-h-32 overflow-y-auto space-y-1 mt-2"></div>
            </div>

            <!-- Карта вровень с колонкой города -->
            <div id="map" class="w-full h-64 bg-gray-100 rounded-lg border border-gray-200 shadow-sm relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center text-gray-400 text-xs text-center p-4">
                    Карта загрузится после выбора города
                </div>
            </div>
        </div>

        <!-- ПРАВАЯ КОЛОНКА (Поиск адреса + Результаты) -->
        <div id="blockInputLocationAddress" class="md:col-span-2 space-y-4">
            <!-- Поле ввода адреса -->
            <div class="form-group">
                <label asp-for="Location.Address" class="block text-sm font-bold text-gray-700 mb-1">Адрес</label>
                <input id="inputLocationAddress" asp-for="Location.Address" 
                       class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 outline-none" 
                       placeholder="Введите улицу и номер дома..." />
                <span asp-validation-for="Location.Address" class="text-red-500 text-xs mt-1"></span>
            </div>

            <!-- Результаты поиска вровень с полем адреса -->
            <div class="form-group">
                <div id="LocationInMap">
                </div>
            </div>
        </div>
    </div>

    <!-- Загрузчик (индикатор процесса) -->
    <div id="loaderNewLocation" class="hidden py-4 flex flex-col items-center border border-dashed border-blue-200 rounded-lg bg-blue-50/50">
        <div class="animate-spin rounded-full h-6 w-6 border-t-2 border-b-2 border-blue-600"></div>
        <span class="text-xs text-blue-600 mt-2 font-medium">Синхронизация с картой...</span>
    </div>

    <!-- Секция загрузки фото (на всю ширину) -->
    <div class="pt-4 border-t border-gray-100">
        <label asp-for="@Model.Location.imagesLocation" class="block text-xs font-bold text-gray-500 uppercase mb-2">Фотографии объекта</label>
        <div class="flex items-center justify-center w-full">
            <input asp-for="@Model.Location.imagesLocation" type="file" multiple accept="image/*"
                   class="block w-full text-sm text-gray-500
                          file:mr-4 file:py-2.5 file:px-4
                          file:rounded-md file:border-0
                          file:text-sm file:font-semibold
                          file:bg-gray-100 file:text-gray-700
                          hover:file:bg-gray-200
                          border border-gray-300 rounded-lg p-1 bg-white cursor-pointer" />
        </div>
    </div>

    <!-- Скрытые координаты для передачи в контроллер -->
    <input type="hidden" asp-for="Location.LocationLongitude" />
    <input type="hidden" asp-for="Location.LocationLatitude" />
</fieldset>
            @if (ViewData.ModelState.ContainsKey("inputLocationAddress") && ViewData.ModelState["inputLocationAddress"].Errors.Count > 0)
            {
                <span class="text-red-500 text-sm mt-1 ml-1">
                    @ViewData.ModelState["inputLocationAddress"].Errors[0].ErrorMessage
