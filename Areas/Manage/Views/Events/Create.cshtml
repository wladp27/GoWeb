        const { YMap, YMapDefaultSchemeLayer, YMapDefaultFeaturesLayer, YMapMarker } = ymaps3;

        // Инициализация карты
        map = new YMap(document.getElementById('map'), {
            location: {
                center: [lon,lat], 
                zoom: 12
            }
        });
        marker = new YMapMarker(
                {
                    coordinates: [lon,lat],
                    draggable: true,
                    zIndex: 100
                },
                content);
       
        // Добавляем необходимые слои
        map.addChild(new YMapDefaultSchemeLayer());
        map.addChild(new YMapDefaultFeaturesLayer());
       


    
    }

    // Инициализация при загрузке окна
        let searchTimeout5;
        async function SearchLocation()
        {
            
            await ymaps3.ready;
            const addressInput = document.getElementById("inputLocationAddress");
            const resultsContainer = document.getElementById('LocationInMap');
            const loader = document.getElementById('loaderNewLocation');
            const btn= document.getElementById("buttonEventSave");
            const idCity = document.getElementById("selectLocationCityId");
            const name = addressInput.value.trim();
            const locationLongitude =  document.getElementById("Location_LocationLongitude");
            const locationLatitude =  document.getElementById("Location_LocationLatitude");
            
             if(!idCity.value)
        {
            resultsContainer.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Выберите город</div>';
            return;
        }
        const selectedCityName = citySelect.options[idCity.selectedIndex]; // проверку на существующий город сделать
        resultsContainer.innerHTML ="";
        if (!name) {
            resultsContainerValidation.innerHTML = '<div class="text-amber-600 text-sm p-3 bg-amber-50 rounded-lg border border-amber-200">Введите адресс локации</div>';
            return;
        }
        const fullName = `${selectedCityName.text}, ${name}`;
        const {YMapMarker } = ymaps3;
        const listLocation = await ymaps3.search({
                                                        text: fullName,
                                                        limit: 5
                                                        });

         


            if (!listLocation || listLocation.length === 0) 
            {
                resultsContainer.innerHTML = '<div class="text-gray-500 text-sm italic p-3 text-center">Никого не нашли...</div>';
                return;
            }
            resultsContainer.innerHTML = '';
            listLocation.forEach(location => 
             {
                const locationElement = document.createElement('div');
                locationElement.className = "p-3 border border-gray-200 rounded-xl hover:bg-blue-50 cursor-pointer flex justify-between items-center bg-white transition hover:border-blue-300 mb-2";
                locationElement.innerHTML = `
                                                <div class="flex flex-col">
                                                    <span class="font-bold text-gray-700">${location.properties.name}</span>
                                                    <span class="text-xs text-gray-500">${location.properties.description}</span>
                                                </div>
                                                <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full uppercase">Выбрать</span>
                                            `;
                locationElement.onclick = async() => 
                {
                    map.update({
                                         location: {
                                             center: [location.geometry.coordinates[0],location.geometry.coordinates[1]], // Центр карты.
                                             zoom: 18, // Уровень зума.
                                             duration: 200, // Анимация карты займет 200 миллисекунд.
                                             easing: 'ease-in-out' // Функция анимации изменения местоположения на карте.
                                         }
                                        });
                
                    content.style.cssText = 'width: 25px; height: 25px; position: relative; transform: translate(-50%, -50%);';
                    content.innerHTML = `<img src="/images/markers/voleyball.png" style="width: 100%; height: 100%; display: block; cursor: pointer;">`;
                    if(marker==null)
                    {
                        marker = new YMapMarker(
                       {
                           coordinates: [location.geometry.coordinates[0],location.geometry.coordinates[1]],
                           draggable: true,
                           zIndex: 100
                       },
                       content);

                    }
                    else
                    {
                        map.removeChild(marker);
                        marker = new YMapMarker(
                       {
                           coordinates: [location.geometry.coordinates[0],location.geometry.coordinates[1]],
                           draggable: true,
                           zIndex: 100
                       },
                       content);
                       map.addChild(marker);
                    }
                    const fullAddress = `${location.properties.description}, ${location.properties.name}`;
                    const response = await fetch(`/Manage/Events/CheckLocation?newAddress=${encodeURIComponent(fullAddress)}&idCity=${encodeURIComponent(idCity.value)}`);
                    loader.classList.remove('hidden');
                    addressInput.value=fullAddress;
                    if (!response.ok) 
                        throw new Error(`Ошибка сервера`);
                    const hasLocation = await response.json();
                    if (hasLocation) 
                    {
                        resultsContainer.innerHTML = `
                                                    <div class="w-full block text-amber-600 text-sm p-4 bg-amber-50 rounded-lg border border-amber-200 shadow-sm">
                                                        Данная локация уже существует, закройте модуль создания и выберите её в списке выше
                                                    </div>`;
                        loader.classList.add('hidden');
                        btn.disabled = true;
                        return;
                    }
                    resultsContainer.innerHTML =`<div class="p-3 bg-green-50 text-green-700 rounded-xl border border-green-200 flex items-center font-bold">✓ Данной локации нет в базе </div>`;
                    btn.disabled = false;
                    locationLongitude.value = location.geometry.coordinates[0].toString().replace('.', ',');
                    locationLatitude.value = location.geometry.coordinates[1].toString().replace('.', ',');
                    resultsContainer.innerHTML =`<div class="p-3 bg-green-50 text-green-700 rounded-xl border border-green-200 flex items-center font-bold">✓ Данной локации нет в базе </div>`;
                    loader.classList.add('hidden');
                };
                resultsContainer.appendChild(locationElement);
            });
        }

        document.getElementById('inputLocationAddress').addEventListener('input', (e) => {
        e.target.dataset.selected = "false";
        clearTimeout(searchTimeout5);
        searchTimeout5 = setTimeout(() => {
            if (e.target.dataset.selected !== "true") {
                SearchLocation();
            }
        }, 200);
    });
</script>