<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GoWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-toggleable-lg navbar-light bg-white border-bottom box-shadow mb-4">
            <div class="container-fluid">
                <!-- Логотип -->
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">GoWeb</a>

                <!-- Кнопка бургер-меню для мобилок -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <!-- Левая часть: Основная навигация -->
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Event" asp-action="Index">События</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="User" asp-controller="Event" asp-action="MyEvents">Мои события</a>
                            </li>

                            @if (User.IsInRole("Администратор"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-area="Admin" asp-controller="Editor" asp-action="Index">Админка</a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Правая часть: Профиль и Авторизация -->
                    <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="navbar-text me-2 text-secondary">
                                Привет, <strong>@User.Identity.Name</strong>!
                            </span>
                            <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">Выход</a>
                        }
                        else
                        {
                            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">Вход</a>
                            <a asp-area="" asp-area="" asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Регистрация</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-auto">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2026 - GoWeb</span>
            <a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Privacy">Конфиденциальность</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @* Валидацию лучше подключать только там, где есть формы, но если нужно глобально — оставляем здесь *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>